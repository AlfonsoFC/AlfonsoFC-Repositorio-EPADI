/* 1. EPADI_ACTUALIZAR_PACIENTES */
DELETE FROM EPADI_PACIENTES;

INSERT INTO EPADI_PACIENTES (
    "NUHSA", "Primer Apellido", "Segundo Apellido", "Nombre", "Teléfono",
    "Teléfono 2", "Tipo Via", "Nombre Via", "Numero Via", "Bloque", 
    "Escalera", "Usuario Actual Piso", "Puerta", "Clave Médica", "Clave Equipo", "Sexo",
    "Fecha Nacimiento", "Localidad", "Distrito Habitual"
)
// Eliminamos nulos tipificados en documentación como -1, asignandolos el valor correcto)
SELECT
    t.COD_NUHSA, t.DESC_APELLIDO_UNO, t.DESC_APELLIDO_DOS, t.DESC_Nombre,
    NULLIF(t.TELEFONO, '-1'), NULLIF(t.MOVIL, '-1'), NULLIF(t.COD_TIPO_VIA, '-1'), NULLIF(t.NOM_VIA, '-1'), NULLIF(t.NUM_VIA, '-1'), 
    NULLIF(t.BLOQUE_DOMICILIO, '-1'), NULLIF(t.ESCALERA, '-1'), NULLIF(t.PISO, '-1'),  NULLIF(t.PUERTA, '-1'),
    t.COD_CLAVE_MEDICA, t.COD_CLAVE_EQUIPO,
    DECODE(t.COD_SEXO, 0, 'Hombre', 1, 'Mujer'), t.COD_FEC_NACIMIENTO,
    t.DESC_MUNICIPIO, t.COD_DISTRITO
FROM TM_BDU t
JOIN (
    SELECT NUHSA FROM EPADI_PROGRAMA_SALUD WHERE UPPER(NOMBRE_TIPO) LIKE '%PLURIPA%'
    UNION
    SELECT NUHSA FROM EPADI_PROGRAMA_SALUD WHERE UPPER(NOMBRE_TIPO) LIKE '%INMOVILIZADOS%'
    UNION
    SELECT NUHSA FROM EPADI_PROCESO_ASISTENCIAL WHERE UPPER(NOMBRE_TIPO) LIKE '%PLURIPA%'
    UNION
    SELECT NUHSA FROM EPADI_PROCESO_ASISTENCIAL WHERE UPPER(NOMBRE_TIPO) LIKE '%INMOVILIZADOS%'
    UNION
    SELECT NUHSA FROM EPADI_CRONICOS_PRIORIZADOS
    UNION
    SELECT COD_NUHSA FROM TM_BDU WHERE COD_EDAD > 79
) fuente
  ON fuente.nuhsa = t.COD_NUHSA;


/* 2. ELIMINAR_ESCALAS_NO_VIGENTES. Toma valores de escalas obsoletas y los elimina */
DELETE FROM EPADI_ESCALA
WHERE ROWID IN (
    SELECT rid
    FROM (
        SELECT ROWID AS rid,
               ROW_NUMBER() OVER (
                   PARTITION BY nuhsa, cod_cuestionario
                   ORDER BY f_cuestionario DESC, puntuacion DESC
               ) AS rn
        FROM EPADI_ESCALA
        WHERE cod_cuestionario IN ( "Num. escalas obsoletas" )
    )
    WHERE rn > 1
);

/* 3. Insertar asistenciales */
DELETE FROM EPADI_ASISTENCIALES;
INSERT INTO EPADI_ASISTENCIALES (NUHSA)
    SELECT "Usuario Actual NUHSA" FROM EPADI_PACIENTES;

/* 4. Actualizar Escalas: ejemplo Barthel, de igual manera para el resto de escalas: Pfeiffer, Valoración Social y Epadi */
MERGE INTO EPADI_ASISTENCIALES asis
USING (
    SELECT nuhsa, puntuacion
    FROM (
        SELECT esc.nuhsa,
               esc.puntuacion,
               ROW_NUMBER() OVER (
                   PARTITION BY esc.nuhsa
                   ORDER BY esc.f_cuestionario DESC, esc.puntuacion DESC
               ) AS rn
        FROM EPADI_ESCALA esc
        WHERE UPPER(esc.cuestionario) LIKE '%BARTHEL%'
    )
    WHERE rn = 1
) ult
ON (asis.nuhsa = ult.nuhsa)
WHEN MATCHED THEN
    UPDATE SET asis.barthel = ult.puntuacion;

/* 5. Actualizar Epadi Asistenciales, se toman los valores: inmovilizado, pasivo (de TM_BDU) y pluripatologico. */
MERGE INTO EPADI_ASISTENCIALES asis
USING (
    SELECT DISTINCT ps.nuhsa
    FROM EPADI_PROGRAMA_SALUD ps
    WHERE UPPER(ps.nombre_tipo) LIKE '%INMOVILIZADO%'
    
    UNION
    
    SELECT DISTINCT pa.nuhsa
    FROM EPADI_PROCESO_ASISTENCIAL pa
    WHERE UPPER(pa.nombre_tipo) LIKE '%INMOVILIZADO%'
) fuente
ON (asis.nuhsa = fuente.nuhsa)
WHEN MATCHED THEN
    UPDATE SET asis.inmovilizado = 1
    WHERE asis.inmovilizado IS NULL   -- incluye NULL
       OR asis.inmovilizado = 0;      -- incluye 0

